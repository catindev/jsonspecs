{
  "name": "jsonspecs",
  "version": "1.0.1",
  "description": "Composable validation pipelines powered by JSON rules",
  "type": "commonjs",
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "require": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src/**/*.js",
    "README.md",
    "OPERATORS.md",
    "SPEC.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test tests/compiler.test.js tests/runner.test.js",
    "test:smoke": "node examples/basic/run.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "validation",
    "rules-engine",
    "json",
    "declarative",
    "pipeline",
    "business-rules"
  ],
  "author": "jsonspecs contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": " https://github.com/catindev/jsonspecs"
  },
  "bugs": {
    "url": " https://github.com/catindev/jsonspecs/issues"
  },
  "homepage": " https://github.com/catindev/jsonspecs#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {}
}
